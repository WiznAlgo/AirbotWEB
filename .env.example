# =============================================================
# AirBot Panel - Environment Config (OPSIONAL)
#
# File ini OPSIONAL. Cara paling gampang untuk isi konfigurasi sekarang
# adalah edit langsung "server/config.js" (isi token di sana, tidak perlu
# .env sama sekali). Kalau kamu tetap lebih suka pakai .env/Environment
# Variables (mis. supaya token tidak ikut ke-commit ke git), isi file ini
# dan nilainya akan otomatis dipakai duluan (menimpa isi config.js).
# =============================================================

# Port untuk backend panel ini (bukan port bot)
PORT=4000
NODE_ENV=development

# Base URL REST API tiap bot (tanpa trailing slash, sudah termasuk /api)
BOT_BARCODE_BASE_URL=https://bc.radenunlock.com/api
BOT_CEIR_BASE_URL=https://cr.radenunlock.com/api

# Master API token tiap bot -> ambil dari config.js masing-masing bot
# (config.api.authToken). Token ini HANYA dipakai di server (server/lib/botApi.js),
# tidak pernah dikirim ke browser.
BOT_BARCODE_API_TOKEN=barcode-api-change-me
BOT_CEIR_API_TOKEN=ceir-api-change-me

# Secret untuk menandatangani cookie sesi login website ini.
# Isi string acak yang panjang & rahasia, contoh generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang-dan-rahasia

# Umur sesi login (jam)
SESSION_HOURS=12

# Nama cookie sesi (boleh dibiarkan default)
SESSION_COOKIE_NAME=airbot_panel_session
